generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Directive {
  id             String          @id @default(cuid())
  idempotencyKey String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String          @default("sms")
  mode           String          @default("DIRECTIVE")
  title          String?
  text           String
  status         DirectiveStatus @default(RECEIVED)
  metadata       Json?
  provider       String          @default("gemini")
  jobsCreated    Int             @default(0)
  rawModelJson   String?
  error          String?
  events         Event[]         @relation("DirectiveEvents")
  jobs           Job[]

  @@index([status])
  @@index([createdAt])
}

model Job {
  id               String     @id @default(uuid())
  idempotencyKey   String?    @unique
  directiveId      String?
  title            String
  description      String?
  status           JobStatus  @default(QUEUED)
  owner            Owner      @default(MAGGIE)
  risk             Risk       @default(LOW)
  labels           String[]
  requiresApproval Boolean    @default(false)
  blockedReason    String?
  dependsOn        Json?
  leaseToken       String?    @unique
  leaseUntil       DateTime?
  lastHeartbeatAt  DateTime?
  attempts         Int        @default(0)
  lastError        String?
  lastEventAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  events           Event[]    @relation("JobEvents")
  directive        Directive? @relation(fields: [directiveId], references: [id])

  @@index([status, owner])
  @@index([leaseUntil])
  @@index([directiveId])
}

model Event {
  id          String     @id @default(cuid())
  scope       EventScope
  type        String
  level       String     @default("INFO")
  message     String
  payload     Json?
  createdAt   DateTime   @default(now())
  directiveId String?
  jobId       String?
  directive   Directive? @relation("DirectiveEvents", fields: [directiveId], references: [id], onDelete: Cascade)
  job         Job?       @relation("JobEvents", fields: [jobId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([scope, type])
  @@index([directiveId])
  @@index([jobId])
}

model Debate {
  id              String        @id @default(cuid())
  title           String
  trigger         DebateTrigger
  context         String?
  options         Json?
  recommendation  String?
  decision        String?
  decisionBy      String?
  state           DebateState   @default(PROPOSED)
  bartVerified    Boolean       @default(false)
  bartEvidenceUrl String?
  smsOverride     Boolean       @default(false)
  smsOverrideNote String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  events          DebateEvent[]
}

model DebateEvent {
  id        String   @id @default(cuid())
  debateId  String
  type      String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
  Debate    Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@index([debateId])
}

model DecisionLedgerEntry {
  id                  String                @id @default(cuid())
  timestamp           DateTime              @default(now())
  proposalTitle       String
  proposingAgent      DecisionProposingAgent
  ruling              DecisionRuling
  conditions          String?
  summary             String
  stageReference      String
  sourceThreadEventId String?
  createdAt           DateTime              @default(now())

  @@index([timestamp])
  @@index([ruling])
  @@index([stageReference])
}

model ApprovalRequest {
  id          String                @id @default(cuid())
  title       String
  description String
  requestedBy ApprovalRequestedBy
  status      ApprovalStatus        @default(PENDING)
  feedback    String?
  sourceType  String?
  sourceId    String?
  createdAt   DateTime              @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([status])
  @@index([createdAt])
}

enum JobStatus {
  QUEUED
  CLAIMED
  IN_PROGRESS
  QA
  DONE
  FAILED
  BLOCKED
}

enum DecisionProposingAgent {
  LISA
  HOMER
  BART
  MAGGIE
  SMS
}

enum DecisionRuling {
  APPROVED
  APPROVED_WITH_CONDITIONS
  REJECTED
  DIRECTIVE
}

enum ApprovalRequestedBy {
  MAGGIE
  SMS
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Owner {
  HOMER
  BART
  LISA
  MARGE
  MAGGIE
  MIXED
  SMS
}

enum Risk {
  LOW
  MED
  HIGH
}

enum DirectiveStatus {
  QUEUED
  RECEIVED
  PLANNING
  PLANNED
  PROCESSING
  COMPLETED
  FAILED
}

enum EventScope {
  DIRECTIVE
  JOB
  SYSTEM
  AGENT
}

enum DebateTrigger {
  HIGH_RISK
  ARCH_DECISION
  PARITY_UNCERTAIN
  REPEATED_FAILURE
  MANUAL
}

enum DebateState {
  PROPOSED
  DECIDED
  IMPLEMENTING
  VERIFIED
  DONE
}




model FlandersState {
  id                String    @id @default("singleton")
  lastCheckedAt     DateTime  @default(now())
  currentPriorities String    @default("[]")
  pendingItems      String    @default("[]")
  lastDigestAt      DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("FlandersState")
}

model FlandersContext {
  id        String   @id @default(cuid())
  type      String
  summary   String
  detail    String?
  jobId     String?
  agents    String[] @default([])
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("FlandersContext")
}

model FlandersAction {
  id            String   @id @default(cuid())
  messageId     String
  messageText   String
  actionTaken   String
  directiveSent String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@map("FlandersAction")
}
