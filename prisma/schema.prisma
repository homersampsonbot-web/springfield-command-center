generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  BLOCKED
  QA
  DONE
}

enum Owner {
  HOMER
  BART
  LISA
  MARGE
  MAGGIE
  MIXED
  SMS
}

enum Risk {
  LOW
  MED
  HIGH
}

enum DirectiveStatus {
  QUEUED
  PROCESSING
  PLANNED
  FAILED
}

model Directive {
  id           String          @id @default(cuid())
  createdAt    DateTime        @default(now())
  createdBy    String          @default("sms")
  text         String
  status       DirectiveStatus @default(QUEUED)
  provider     String          @default("gemini")
  jobsCreated  Int             @default(0)
  rawModelJson String?         @db.Text
  error        String?         @db.Text
  jobs         Job[]
  events       DirectiveEvent[]
}

model DirectiveEvent {
  id          String   @id @default(cuid())
  directiveId String
  createdAt   DateTime @default(now())
  level       String   // INFO|WARN|ERROR|SUCCESS
  message     String   @db.Text
  directive   Directive @relation(fields: [directiveId], references: [id], onDelete: Cascade)

  @@index([directiveId])
  @@index([createdAt])
}

model Job {
  id               String          @id @default(uuid())
  title            String
  description      String?
  status           JobStatus       @default(QUEUED)
  owner            Owner           @default(MAGGIE)
  risk             Risk            @default(LOW)
  labels           String[]
  requiresApproval Boolean         @default(false)
  blockedReason    String?
  links            Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lastEventAt      DateTime?
  events           JobEvent[]
  lock             JobLock?
  directiveId      String?
  directive        Directive?      @relation(fields: [directiveId], references: [id], onDelete: SetNull)
  dependencies     JobDependency[] @relation("JobDeps")
  dependentOn      JobDependency[] @relation("JobDepsOn")
}

model JobDependency {
  id             String @id @default(cuid())
  jobId          String
  dependsOnJobId String
  job            Job    @relation("JobDeps", fields: [jobId], references: [id], onDelete: Cascade)
  dependsOn      Job    @relation("JobDepsOn", fields: [dependsOnJobId], references: [id], onDelete: Cascade)

  @@unique([jobId, dependsOnJobId])
}

model JobEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  jobId     String?
  type      String   // INFO|STATUS_CHANGE|ERROR|DIRECTIVE
  message   String   @db.Text
  payload   Json?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([jobId])
}

model JobLock {
  id        String   @id @default(uuid())
  jobId     String   @unique
  ownerId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
